# Vercel Environment Variables Template
# Copy these to Vercel Dashboard → Settings → Environment Variables

# Application
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:M570kiRicjrzUU+yxyREi3ULX2pKmV4rx3LzuLHFL1s=
APP_URL=https://your-domain.vercel.app
APP_NAME=NutriCare

# Database - CHOOSE ONE DATABASE TYPE BELOW

## PlanetScale MySQL (Recommended for ease)
DB_CONNECTION=mysql
DB_HOST=aws.connect.psdb.cloud
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

## Supabase PostgreSQL (Alternative)
# DB_CONNECTION=pgsql
# DB_HOST=your-ref.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=your_password

## Vercel PostgreSQL (Native)
# DB_CONNECTION=pgsql
# Automatically injected by Vercel

# Cache & Sessions (Optimized for Serverless)
CACHE_STORE=array
SESSION_DRIVER=cookie
SESSION_ENCRYPT=true
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
LOG_LEVEL=error

# File Storage - CHOOSE ONE
FILESYSTEM_DISK=local
# Or use S3 for production:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=your_bucket

# Optional: Monitoring & Observability
# SENTRY_LARAVEL_DSN=your_sentry_dsn
# LOG_SLACK_WEBHOOK_URL=your_slack_webhook

# Locale
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Mail (Optional)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=NutriCare

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file

# Vercel Detection Flag
VERCEL=1

# Add any other sensitive variables your app needs (API keys, etc.)
